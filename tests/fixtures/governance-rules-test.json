{
  "version": "1.0",
  "dependency_rules": {
    "max_transitive_depth": 4,
    "no_circular_dependencies": true,
    "no_back_edges": true,
    "restricted_organs": ["ORGAN-I", "ORGAN-II", "ORGAN-III"],
    "restricted_orgs": ["organvm-i-theoria", "organvm-ii-poiesis", "organvm-iii-ergon"]
  },
  "promotion_rules": {
    "promote-to-art": {
      "source_organ": "ORGAN-I",
      "destination_organ": "ORGAN-II",
      "conditions": ["Source repo has documentation"],
      "naming": "art-from--{source_repo_name}"
    }
  },
  "state_machine": {
    "states": ["LOCAL", "CANDIDATE", "PUBLIC_PROCESS", "GRADUATED", "ARCHIVED"],
    "transitions": {
      "LOCAL": ["CANDIDATE", "ARCHIVED"],
      "CANDIDATE": ["PUBLIC_PROCESS", "LOCAL", "ARCHIVED"],
      "PUBLIC_PROCESS": ["GRADUATED", "CANDIDATE", "ARCHIVED"],
      "GRADUATED": ["ARCHIVED"],
      "ARCHIVED": []
    }
  },
  "audit_thresholds": {
    "critical": {
      "missing_readme": true,
      "circular_dependency": true,
      "back_edge_violation": true,
      "organ_has_zero_repos": true
    },
    "warning": {
      "stale_repo_days": 90,
      "missing_changelog": true,
      "missing_ci_workflow": true
    }
  },
  "organ_requirements": {
    "ORGAN-I": { "min_repos": 1, "requires_readme": true },
    "ORGAN-II": { "min_repos": 1, "requires_readme": true },
    "ORGAN-III": { "min_repos": 1, "requires_readme": true }
  },
  "dictums": {
    "schema_version": "1",
    "preamble": "Test dictums.",
    "axioms": [
      {
        "id": "AX-1",
        "name": "DAG Invariant",
        "statement": "Strict DAG: I→II→III.",
        "enforcement": "automated",
        "validator": "validate_dag_invariant",
        "references": ["governance/dependency_graph.py"],
        "severity": "critical"
      },
      {
        "id": "AX-2",
        "name": "Epistemic Membranes",
        "statement": "Cross-organ edges must be declared in seed.yaml.",
        "enforcement": "audit",
        "validator": "validate_epistemic_membranes",
        "references": ["seed/graph.py"],
        "severity": "critical"
      },
      {
        "id": "AX-3",
        "name": "TTL Eviction",
        "statement": "90-day staleness, 14-day INCUBATOR TTL.",
        "enforcement": "automated",
        "validator": "validate_ttl_eviction",
        "references": ["governance/audit.py"],
        "severity": "warning"
      },
      {
        "id": "AX-4",
        "name": "Registry Coherence",
        "statement": "No duplicates, counts match, no empty names.",
        "enforcement": "automated",
        "validator": "validate_registry_coherence",
        "references": ["constitution.md Article I"],
        "severity": "critical"
      },
      {
        "id": "AX-7",
        "name": "Tetradic Self-Knowledge",
        "statement": "Every non-archived formation must articulate telos, pragma, praxis, receptio.",
        "enforcement": "audit",
        "validator": "validate_tetradic_self_knowledge",
        "references": ["constitution.md Amendment G"],
        "severity": "warning"
      },
      {
        "id": "AX-8",
        "name": "Constructed Polis",
        "statement": "Every non-archived formation must construct its own idealized critical society.",
        "enforcement": "audit",
        "validator": "validate_constructed_polis",
        "references": ["constitution.md Amendment H"],
        "severity": "warning"
      },
      {
        "id": "AX-9",
        "name": "Triple Reference Invariant",
        "statement": "Every referenceable system item must exist in exactly three places.",
        "enforcement": "audit",
        "validator": "validate_triple_reference",
        "references": ["SPEC-025 Predicate 3"],
        "severity": "warning"
      }
    ],
    "organ_dictums": {
      "ORGAN-III": [
        {
          "id": "OD-III",
          "name": "Ergon Factory Gate",
          "statement": "ORGAN-III repos must have revenue_model and CI.",
          "constraints": { "requires_revenue_model": true, "requires_ci": true },
          "enforcement": "automated",
          "validator": "validate_organ_iii_factory",
          "severity": "warning"
        }
      ],
      "ORGAN-IV": [
        {
          "id": "OD-IV",
          "name": "Taxis Orchestration",
          "statement": "ORGAN-IV orchestrates.",
          "constraints": {},
          "enforcement": "manual",
          "validator": null,
          "severity": "info"
        }
      ],
      "ORGAN-V": [
        {
          "id": "OD-V",
          "name": "Logos Write Scope",
          "statement": "Produces only to ORGAN-V.",
          "constraints": { "write_scope": "self_only" },
          "enforcement": "audit",
          "validator": "validate_logos_write_scope",
          "severity": "warning"
        }
      ],
      "ORGAN-VII": [
        {
          "id": "OD-VII",
          "name": "Kerygma Consumer",
          "statement": "No produces edges.",
          "constraints": { "no_produces": true },
          "enforcement": "audit",
          "validator": "validate_kerygma_consumer",
          "severity": "warning"
        }
      ]
    },
    "repo_rules": [
      {
        "id": "RR-1",
        "name": "Seed Contract Mandate",
        "statement": "Every non-archived repo must have seed.yaml.",
        "enforcement": "automated",
        "validator": "validate_seed_mandate",
        "references": ["seed/discover.py"],
        "severity": "warning",
        "applies_to": "all non-archived repos"
      },
      {
        "id": "RR-2",
        "name": "Single Responsibility",
        "statement": "Each repo should have a single responsibility.",
        "enforcement": "manual",
        "validator": null,
        "references": [],
        "severity": "info",
        "applies_to": "all repos"
      },
      {
        "id": "RR-3",
        "name": "Event Handshake",
        "statement": "Event edges must reference existing events.",
        "enforcement": "audit",
        "validator": "validate_event_handshake",
        "references": ["seed/graph.py"],
        "severity": "warning",
        "applies_to": "repos with event edges"
      },
      {
        "id": "RR-4",
        "name": "README Mandate",
        "statement": "Every non-archived repo must have documentation.",
        "enforcement": "automated",
        "validator": "validate_readme_mandate",
        "references": ["constitution.md Article V"],
        "severity": "warning",
        "applies_to": "all non-archived repos"
      },
      {
        "id": "RR-5",
        "name": "Promotion Integrity",
        "statement": "Valid promotion_status from state machine.",
        "enforcement": "automated",
        "validator": "validate_promotion_integrity",
        "references": ["constitution.md Article VI"],
        "severity": "warning",
        "applies_to": "all repos"
      },
      {
        "id": "RR-9",
        "name": "Effect Obligation",
        "statement": "Every non-archived repo must produce at least one traceable effect.",
        "enforcement": "audit",
        "validator": "validate_effect_obligation",
        "references": ["SPEC-025 Predicate 3 (EFFECT)"],
        "severity": "warning",
        "applies_to": "all non-archived repos with seed.yaml"
      }
    ]
  }
}
